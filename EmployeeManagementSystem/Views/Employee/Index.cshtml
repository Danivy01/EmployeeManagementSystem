@model List<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Index";
}

<h1 class="text-center">Employee Masterlist</h1>

<a class="btn btn-primary mt-2" asp-action="Create" asp-controller="Employee">Add Employee</a>
<table class="table table-borderless table-striped table-responsive mt-2">
    <thead class="thead-light">
        <tr>
            <th>ID</th>
            <th>Employee</th>
            <th>Department</th>
            <th>Position</th>
            <th>Date Hired</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var employee in Model)
    {
    
        <tr>
            <td>@employee.EmployeeID</td>
            <td>@employee.FullName</td>
            <td>@employee.Department</td>
            <td>@employee.Position</td>
            <td>@employee.DateHired.ToShortDateString()</td>
            <td>
                <div class="d-flex">
                    <a asp-action="Edit" asp-controller="Employee" asp-route-id="@employee.ID" class="text-primary"><i class="fa-solid fa-pen"></i></a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
